	<queryString language="SQL">
		<![CDATA[select
	eccs_empleado.ID AS codigo,
    eccs_empleado.nombre || eccs_empleado.apellidop || eccs_empleado.apellidom as nombre,
    eccs_empleado.rfc,
    --rh_empleado.curp,
    to_char(eccs_empleado.fecharegistro, 'dd/mm/yyyy') AS fechaingreso,
    eccs_empleado.correo_personal,
    coalesce( eccs_empleado.cuenta_banco, 0) as banco,
    coalesce( eccs_empleado.clabe, 0 ) as clabe,
    eccs_estatus.descripcion as estatus,
    to_char(now(), 'dd/mm/yyyy hh:mm') Rfecha
from eccs_empleado
left join eccs_estatus on eccs_estatus.id = eccs_empleado.id_estatus
order by eccs_empleado.nombre]]>
	</queryString>
